{
    "name": "phpthis/skeleton",
    "description": "A checked, minimal PHPThis application starting point.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "~8.4.0",
        "phpthis/framework": "0.1.0-alpha.3"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "profile": "phpthis check",
        "test": "php tests/run.php",
        "check": [
            "@profile",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": false,
        "sort-packages": true
    }
}
